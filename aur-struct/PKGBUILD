# Maintainer: Kingkor Roy Tirtho <krtirho@gmail.com>
pkgname=kelletube-bin
pkgver=%{{SPOTUBE_VERSION}}%
pkgrel=%{{PKGREL}}%
epoch=
pkgdesc="Open source Music client that doesn't require Premium nor uses Electron! Available for both desktop & mobile!"
arch=(x86_64)
url="https://kelletube.krtirtho.dev"
license=('BSD-4-Clause')
groups=()
depends=('mpv' 'libappindicator-gtk3' 'libsecret' 'jsoncpp' 'libnotify' 'xdg-user-dirs' 'webkit2gtk-4.1')
makedepends=()
checkdepends=()
optdepends=('yt-dlp-git')
provides=()
conflicts=()
replaces=()
backup=()
options=()
install=
changelog=
source=("https://github.com/KRTirtho/kelletube/releases/download/v${pkgver}/kelletube-linux-${pkgver}-x86_64.tar.xz")
noextract=()
md5sums=(%{{LINUX_MD5}}%)
validpgpkeys=()

package() {
  install -dm755 "${pkgdir}/usr/share/icons/kelletube"
  install -dm755 "${pkgdir}/usr/share/applications"
  install -dm755 "${pkgdir}/usr/share/appdata"
  install -dm755 "${pkgdir}/usr/share/${pkgname}"
  install -dm755 "${pkgdir}/usr/bin"

  mv ./kelletube.desktop "${pkgdir}/usr/share/applications"
  mv ./kelletube-logo.png "${pkgdir}/usr/share/icons/kelletube/"
  mv ./com.github.Kellecore.Kelletube.appdata.xml "${pkgdir}/usr/share/appdata/kelletube.appdata.xml"
  cp -ra ./data ./lib ./kelletube "${pkgdir}/usr/share/${pkgname}"
  sed -i 's|com.github.Kellecore.Kelletube|kelletube|' "${pkgdir}/usr/share/appdata/kelletube.appdata.xml"
  ln -s "/usr/share/${pkgname}/kelletube" "${pkgdir}/usr/bin/kelletube"
}
